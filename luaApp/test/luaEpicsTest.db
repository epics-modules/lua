# Test records for the epics library (epics.get, epics.put, epics.pv)

record(ai, "$(P)test_ai") {
	field(VAL,  "42.5")
	field(PINI, "YES")
}

record(ao, "$(P)test_ao") {
}

record(longin, "$(P)test_li") {
	field(VAL,  "100")
	field(PINI, "YES")
}

record(stringin, "$(P)test_si") {
	field(VAL,  "hello")
	field(PINI, "YES")
}

record(stringout, "$(P)test_so") {
}

record(waveform, "$(P)test_dwf") {
	field(FTVL, "DOUBLE")
	field(NELM, "5")
}

record(waveform, "$(P)test_cwf") {
	field(FTVL, "CHAR")
	field(NELM, "256")
}
