# Test databases for luaPortDriver

record(ai, "$(P)readback") {
    field(DTYP, "asynInt32")
    field(INP,  "@asyn($(PORT),0) READBACK")
    field(SCAN, "Passive")
}

record(ao, "$(P)setpoint") {
    field(DTYP, "asynInt32")
    field(OUT,  "@asyn($(PORT),0) SETPOINT")
    field(SCAN, "Passive")
}

record(ai, "$(P)float_rb") {
    field(DTYP, "asynFloat64")
    field(INP,  "@asyn($(PORT),0) FLOAT_RB")
    field(SCAN, "Passive")
}
